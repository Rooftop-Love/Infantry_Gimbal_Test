{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Cortex-Debug: CMSIS-DAP",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/Debug/basic_framework.elf",
      "request": "launch",
      "type": "cortex-debug",
      "device": "STM32F407IG",
      "svdFile": "${workspaceFolder}/STM32F407.svd",
      "servertype": "openocd",
      "configFiles": [
        "${workspaceFolder}/openocd_dap.cfg"
      ],
      "runToEntryPoint": "main",
      "rtos": "FreeRTOS",
      "preLaunchTask": "CMake: Build Debug",
      "liveWatch": {
        "enabled": true,
        "samplesPerSecond": 4
      }
    },
    {
      "name": "Cortex-Debug: J-Link",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/Debug/basic_framework.elf",
      "request": "launch",
      "type": "cortex-debug",
      "device": "STM32F407IG",
      "svdFile": "${workspaceFolder}/STM32F407.svd",
      "servertype": "jlink",
      "interface": "swd",
      "runToEntryPoint": "main",
      "rtos": "FreeRTOS",
      "preLaunchTask": "CMake: Build Debug",
      "liveWatch": {
        "enabled": true,
        "samplesPerSecond": 4
      }
    },
    {
      "name": "Cortex-Debug: J-Link + RTT",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/Debug/basic_framework.elf",
      "request": "launch",
      "type": "cortex-debug",
      "device": "STM32F407IG",
      "svdFile": "${workspaceFolder}/STM32F407.svd",
      "servertype": "jlink",
      "interface": "swd",
      "runToEntryPoint": "main",
      "rtos": "FreeRTOS",
      "preLaunchTask": "CMake: Build Debug",
      "liveWatch": {
        "enabled": true,
        "samplesPerSecond": 4
      },
      "rttConfig": {
        "enabled": true,
        "address": "auto",
        "decoders": [
          {
            "label": "RTT",
            "port": 0,
            "type": "console"
          }
        ]
      }
    },
    {
      "name": "Cortex-Debug: CMSIS-DAP Attach",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/Debug/basic_framework.elf",
      "request": "attach",
      "type": "cortex-debug",
      "device": "STM32F407IG",
      "svdFile": "${workspaceFolder}/STM32F407.svd",
      "servertype": "openocd",
      "configFiles": [
        "${workspaceFolder}/openocd_dap.cfg"
      ],
      "rtos": "FreeRTOS",
      "liveWatch": {
        "enabled": true,
        "samplesPerSecond": 4
      }
    },
    {
      "name": "Cortex-Debug: J-Link Attach",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/Debug/basic_framework.elf",
      "request": "attach",
      "type": "cortex-debug",
      "device": "STM32F407IG",
      "svdFile": "${workspaceFolder}/STM32F407.svd",
      "servertype": "jlink",
      "interface": "swd",
      "rtos": "FreeRTOS",
      "liveWatch": {
        "enabled": true,
        "samplesPerSecond": 4
      }
    }
  ]
}
