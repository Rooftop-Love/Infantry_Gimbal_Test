{
  "configurations": [
    {
      "name": "Win32",
      "includePath": [
        "${workspaceFolder}/**"
      ],
      "defines": [
        "_DEBUG",
        "USE_HAL_DRIVER",
        "STM32F407xx",
        "ARM_MATH_CM4",
        "ARM_MATH_MATRIX_CHECK",
        "ARM_MATH_ROUNDING"
      ],
      "cStandard": "c17",
      "cppStandard": "gnu++17",
      "intelliSenseMode": "windows-gcc-arm",
      "configurationProvider": "ms-vscode.cmake-tools",
      "compilerPath": "arm-none-eabi-gcc"
    }
  ],
  "version": 4
}
